    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lit-pigeon/whatsapp-editor": "workspace:^",
    "@lit/react": "^1.0.6"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
