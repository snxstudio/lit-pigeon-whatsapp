{
  "name": "@lit-pigeon/whatsapp-react",
  "version": "0.0.0",
  "description": "React wrapper for the <pigeon-whatsapp-editor> WhatsApp template editor web component.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
