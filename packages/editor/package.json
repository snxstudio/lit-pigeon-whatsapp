  "repository": {
    "type": "git",
    "url": "https://github.com/snxstudio/lit-pigeon-whatsapp.git",
    "directory": "packages/editor"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lit-pigeon/whatsapp-core": "workspace:^"
  },
  "peerDependencies": {
    "lit": "^3"
  },
  "devDependencies": {
