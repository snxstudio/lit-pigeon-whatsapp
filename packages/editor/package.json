{
  "name": "@lit-pigeon/whatsapp-editor",
  "version": "0.0.0",
  "description": "Lit web components to build, preview, and validate WhatsApp Business message templates.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
